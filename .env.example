# Environment variables for vlog-editor-fast

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Database
DATABASE_URL=sqlite:///~/.vlog-editor/projects/project.db

# Project paths
PROJECT_BASE_DIR=~/.vlog-editor/projects

# Media processing
MAX_VIDEO_DURATION=3600
MAX_PHOTO_SIZE_MB=100
SUPPORTED_VIDEO_FORMATS=mp4,mov,avi,mkv,flv,wmv
SUPPORTED_PHOTO_FORMATS=jpg,jpeg,png,gif,bmp,tiff

# Validation thresholds
MIN_NARRATIVE_LENGTH=150
MIN_VIDEO_COUNT=5
MIN_PHOTO_COUNT=50
MIN_TOTAL_DURATION=600

# Logging
LOG_LEVEL=INFO
LOG_FILE=~/.vlog-editor/logs/vlog-editor.log
