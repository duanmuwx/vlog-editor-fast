# Backend runtime
APP_ENV=development
APP_DATA_DIR=~/.vlog-editor
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# Optional external integrations
KIMI_API_KEY=

# Renderer dev only
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Notes
# - Development mode reads values from your shell or local env file.
# - Electron production mode injects APP_ENV, APP_DATA_DIR, SERVER_HOST, and SERVER_PORT automatically.
